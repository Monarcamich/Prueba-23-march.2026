# F1 Rhythm Analysis - Environment Variables

# API Configuration
ERGAST_API_BASE_URL=https://ergast.com/api/f1
ERGAST_TIMEOUT=30

# Data Configuration
DATA_DIR=data/
RAW_DATA_DIR=data/raw/
PROCESSED_DATA_DIR=data/processed/

# Analysis Configuration
SEASONS_TO_FETCH=2020,2021,2022,2023,2024
MIN_LAPS_FOR_ANALYSIS=5
OUTLIER_PERCENTILE=2.5

# Output Configuration
OUTPUT_DIR=outputs/
EXPORT_PNG_DPI=300
EXPORT_FORMAT=png

# Visualization Configuration
FIGURE_SIZE_DEFAULT=12,8
COLOR_PALETTE=husl
